{
  "compilerOptions": {
    "target":          "ES2020",
    "module":          "ES2020",
    "lib":             ["ES2020", "DOM"],
    "moduleResolution":"bundler",
    "strict":          true,
    "skipLibCheck":    true,
    "declaration":     true,
    "declarationMap":  true,
    "sourceMap":       true,
    "outDir":          "./dist",
    "rootDir":         "./src"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
