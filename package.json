{
  "name": "@rald/sdk",
  "version": "1.0.0",
  "description": "RALD OS SDK — integrate any product with the RALD ecosystem in minutes",
  "keywords": ["rald", "rald-os", "identity", "africa", "fintech", "wallet", "trust"],
  "author": "LILCKY STUDIO LIMITED",
  "license": "MIT",
  "homepage": "https://learn.rald.cloud/sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ostinato-Loop/rald-sdk"
  },
  "main":   "./dist/index.cjs",
  "module": "./dist/index.js",
  "types":  "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types":   "./dist/index.d.ts"
    },
    "./identity":  { "import": "./dist/modules/identity.js",  "types": "./dist/modules/identity.d.ts" },
    "./trust":     { "import": "./dist/modules/trust.js",     "types": "./dist/modules/trust.d.ts" },
    "./wallet":    { "import": "./dist/modules/wallet.js",    "types": "./dist/modules/wallet.d.ts" },
    "./alia":      { "import": "./dist/modules/alia.js",      "types": "./dist/modules/alia.d.ts" },
    "./mail":      { "import": "./dist/modules/mail.js",      "types": "./dist/modules/mail.d.ts" },
    "./products":  { "import": "./dist/modules/products.js",  "types": "./dist/modules/products.d.ts" }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build":   "tsup",
    "check":   "tsc --noEmit",
    "dev":     "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup":       "^8.1.0",
    "typescript": "^5.4.5"
  },
  "engines": { "node": ">=18" },
  "sideEffects": false
}
